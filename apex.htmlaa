        // ---------- BRANDING STUDIO ----------
        const BrandingStudio = ({ role }) => {
            const [primary, setPrimary] = useState(loadFromLocal(role, 'brand_primary', '#1e3a8a'));
            const [secondary, setSecondary] = useState(loadFromLocal(role, 'brand_secondary', '#3b82f6'));
            const [font, setFont] = useState(loadFromLocal(role, 'brand_font', 'Inter'));
            const [logo, setLogo] = useState(loadFromLocal(role, 'brand_logo', 'https://placehold.co/200x80/1e3a8a/ffffff?text=APEX'));
            const [tempLogo, setTempLogo] = useState('');

            useEffect(() => {
                saveToLocal(role, 'brand_primary', primary);
                saveToLocal(role, 'brand_secondary', secondary);
                saveToLocal(role, 'brand_font', font);
                saveToLocal(role, 'brand_logo', logo);
            }, [primary, secondary, font, logo, role]);

            const exportZip = async () => {
                const zip = new JSZip();
                zip.file("brand.css", `:root{--primary:${primary};--secondary:${secondary};--font:${font}}`);
                if (logo && logo.startsWith('http')) {
                    try {
                        const res = await fetch(logo);
                        const blob = await res.blob();
                        zip.file("logo.png", blob);
                    } catch(e) {}
                }
                const content = await zip.generateAsync({ type: "blob" });
                saveAs(content, "apex-brand-kit.zip");
            };

            return h('div', { className: 'grid md:grid-cols-2 gap-6' },
                h('div', { className: 'space-y-4' },
                    h('div', null, h('label', { className: 'block text-sm font-medium mb-2 text-blue-300' }, 'Primary Color'),
                        h('input', { type: 'color', value: primary, onChange: e => setPrimary(e.target.value), className: 'w-full h-12 rounded-lg cursor-pointer bg-gray-800 border border-gray-600' })),
                    h('div', null, h('label', { className: 'block text-sm font-medium mb-2 text-blue-300' }, 'Secondary Color'),
                        h('input', { type: 'color', value: secondary, onChange: e => setSecondary(e.target.value), className: 'w-full h-12 rounded-lg cursor-pointer bg-gray-800 border border-gray-600' })),
                    h('div', null, h('label', { className: 'block text-sm font-medium mb-2 text-blue-300' }, 'Brand Font'),
                        h('select', { value: font, onChange: e => setFont(e.target.value), className: 'bg-gray-800 p-3 rounded-lg w-full border border-gray-600' },
                            h('option', { value: 'Inter' }, 'Inter'), h('option', { value: 'Poppins' }, 'Poppins'), h('option', { value: 'Montserrat' }, 'Montserrat'))),
                    h('div', null, h('label', { className: 'block text-sm font-medium mb-2 text-blue-300' }, 'Logo URL'),
                        h('div', { className: 'flex gap-2' }, h('input', { value: tempLogo, onChange: e => setTempLogo(e.target.value), className: 'bg-gray-800 flex-1 p-3 rounded-lg border border-gray-600', placeholder: 'https://...' }),
                            h('button', { onClick: () => tempLogo && setLogo(tempLogo), className: 'btn-primary px-6 rounded-lg text-white font-medium' }, 'Set'))),
                    h('button', { onClick: exportZip, className: 'btn-primary w-full py-3 rounded-lg font-medium text-white mt-4' }, h('i', { className: 'fas fa-file-zipper mr-2' }), 'Download Brand Kit (ZIP)')
                ),
                h('div', { className: 'glass-card p-6 rounded-2xl', style: { backgroundColor: secondary+'20', borderTop: `4px solid ${primary}`, fontFamily: font } },
                    h('h3', { style: { color: primary }, className: 'text-2xl font-bold' }, 'APEX Brand Preview'),
                    h('div', { className: 'flex gap-3 mt-4' },
                        h('span', { className: 'px-4 py-2 rounded-full text-white text-sm font-medium', style: { background: primary } }, 'Primary'),
                        h('span', { className: 'px-4 py-2 rounded-full text-white text-sm font-medium', style: { background: secondary } }, 'Secondary')
                    ),
                    h('img', { src: logo, className: 'max-h-20 mt-4 object-contain', alt: 'logo' }),
                    h('p', { className: 'text-sm text-gray-300 mt-4' }, 'Your brand identity is consistent across all marketing materials.')
                )
            );
        };

