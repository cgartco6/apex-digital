                        h('input', { type: 'file', accept: 'image/*', className: 'hidden', onChange: uploadImage })),
                    h('div', { className: 'flex gap-1 bg-gray-700/30 rounded-lg p-1' },
                        h('button', { onClick: () => styleSelected('fontWeight', 'bold'), className: 'bg-gray-600 hover:bg-gray-500 px-3 py-1 rounded text-white transition' }, h('b', null, 'B')),
                        h('button', { onClick: () => styleSelected('fontStyle', 'italic'), className: 'bg-gray-600 hover:bg-gray-500 px-3 py-1 rounded text-white transition' }, h('i', null, 'I')),
                        h('input', { type: 'color', onChange: (e) => styleSelected('fill', e.target.value), className: 'w-8 h-8 rounded cursor-pointer' })),
                    h('button', { onClick: exportPNG, className: 'bg-green-600 hover:bg-green-500 px-4 py-2 rounded-lg text-sm font-medium text-white transition' }, h('i', { className: 'fas fa-download mr-2' }), 'PNG'),
                    h('button', { onClick: saveDesign, className: 'bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded-lg text-sm font-medium text-white transition' }, h('i', { className: 'fas fa-save mr-2' }), 'Save')
                ),
