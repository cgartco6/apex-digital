<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Apex Digital Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.0/fabric.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
    <script src="https://unpkg.com/react@17.0.2/umd/react.development.js"></script>
    <script src="https://unpkg.com/react-dom@17.0.2/umd/react-dom.development.js"></script>
    <style>
        body { background: #0b0f1c; font-family: 'Inter', sans-serif; margin:0; }
        .glass-card { background: rgba(18,24,38,0.85); backdrop-filter: blur(2px); border: 1px solid rgba(249,115,22,0.25); }
        .tab-active { border-bottom: 3px solid #f97316; background: rgba(249,115,22,0.15); color: white; }
        .pro-badge { background: linear-gradient(135deg, #f59e0b, #d97706); }
        .modal-overlay { background: rgba(0,0,0,0.8); backdrop-filter: blur(4px); }
        .layer-item:hover { background: rgba(249,115,22,0.2); }
        .error-fallback { color: #f87171; background: #1e1e2e; padding: 1rem; border-radius: 0.5rem; margin: 1rem; white-space: pre-wrap; }
    </style>
</head>
<body>
    <div id="root"></div>
    <script>
        // ============================================
        //   SIMPLE REACT 17 VERSION – NO createRoot
        // ============================================
        try {
            const { useState, useEffect, useRef } = React;
            const h = React.createElement;
            const Fragment = React.Fragment;

            // Utilities
            const getStorageKey = (role, key) => `${role}_${key}`;
            const saveToLocal = (role, key, data) => localStorage.setItem(getStorageKey(role, key), JSON.stringify(data));
            const loadFromLocal = (role, key, defaultValue) => {
                const raw = localStorage.getItem(getStorageKey(role, key));
                return raw ? JSON.parse(raw) : defaultValue;
            };

            // Constants
            const BANK_DETAILS = {
                bank: "FNB (First National Bank)",
                accountName: "Apex Digital (Pty) Ltd",
                accountNumber: "62849612345",
                branchCode: "250655",
                referencePrefix: "APX"
            };
            const DEFAULT_AD = {
                headline: "Create Scroll-Stopping Social Ads in Minutes",
                copy: "Apex Social Media Ad Creator helps you design high‑conversion ads with AI‑assisted copy and instant previews. No design skills needed.",
                image: "https://placehold.co/600x400/1e293b/f97316?text=Apex+Ad+Creator",
                cta: "Try for Free"
            };

            // ---------- DESIGN STUDIO ----------
            const DesignStudio = ({ role }) => {
                const canvasRef = useRef(null);
                const fabricCanvas = useRef(null);
                const [layers, setLayers] = useState([]);
                const [selectedId, setSelectedId] = useState(null);

                const updateLayers = () => {
                    if (!fabricCanvas.current) return;
                    const objects = fabricCanvas.current.getObjects();
                    setLayers(objects.map((obj, i) => ({ id: i, type: obj.type, text: obj.text || '' })));
                };

                useEffect(() => {
                    if (!canvasRef.current) return;
                    const canvas = new fabric.Canvas(canvasRef.current, {
                        width: 580,
                        height: 360,
                        backgroundColor: '#1f2937',
                    });
                    fabricCanvas.current = canvas;
                    const saved = loadFromLocal(role, 'design_state', null);
                    if (saved) canvas.loadFromJSON(saved, () => canvas.renderAll());
                    else {
                        const defaultText = new fabric.IText('APEX\nDESIGN', { left: 100, top: 120, fontSize: 36, fill: '#f97316', fontFamily: 'Inter' });
                        canvas.add(defaultText);
                        canvas.renderAll();
                    }
                    canvas.on('object:added', updateLayers);
                    canvas.on('object:removed', updateLayers);
                    canvas.on('selection:created', updateLayers);
                    canvas.on('selection:cleared', () => setSelectedId(null));
                    updateLayers();
                    return () => canvas.dispose();
                }, [role]);

                const addText = () => {
                    const text = new fabric.IText('Edit me', { left: 50, top: 50, fontSize: 24, fill: '#fff' });
                    fabricCanvas.current.add(text);
                    fabricCanvas.current.renderAll();
                };
                const addRect = () => {
                    const rect = new fabric.Rect({ width: 80, height: 80, fill: '#f97316', left: 200, top: 200, stroke: 'white' });
                    fabricCanvas.current.add(rect);
                    fabricCanvas.current.renderAll();
                };
                const uploadImage = (e) => {
                    const file = e.target.files[0];
                    if (!file) return;
                    const reader = new FileReader();
                    reader.onload = (ev) => {
                        fabric.Image.fromURL(ev.target.result, (img) => {
                            img.scaleToWidth(150);
                            fabricCanvas.current.add(img);
                            fabricCanvas.current.renderAll();
                        });
                    };
                    reader.readAsDataURL(file);
                };
                const styleSelected = (prop, val) => {
                    const active = fabricCanvas.current.getActiveObject();
                    if (active) {
                        active.set(prop, val);
                        fabricCanvas.current.renderAll();
                    }
                };
                const exportPNG = () => {
                    const dataURL = fabricCanvas.current.toDataURL('png');
                    const link = document.createElement('a');
                    link.download = 'apex-design.png';
                    link.href = dataURL;
                    link.click();
                };
                const saveDesign = () => {
                    const json = JSON.stringify(fabricCanvas.current.toJSON());
                    saveToLocal(role, 'design_state', json);
                    alert('Design saved');
                };

                return h('div', { className: 'space-y-4' },
                    h('div', { className: 'flex flex-wrap gap-2' },
                        h('button', { onClick: addText, className: 'bg-indigo-600 px-3 py-1.5 rounded text-sm' }, h('i', { className: 'fas fa-font mr-1' }), 'Text'),
                        h('button', { onClick: addRect, className: 'bg-emerald-600 px-3 py-1.5 rounded text-sm' }, h('i', { className: 'fas fa-square mr-1' }), 'Shape'),
                        h('label', { className: 'bg-purple-600 px-3 py-1.5 rounded text-sm cursor-pointer' }, h('i', { className: 'fas fa-image mr-1' }), 'Image',
                            h('input', { type: 'file', accept: 'image/*', className: 'hidden', onChange: uploadImage })),
                        h('div', { className: 'flex gap-1' },
                            h('button', { onClick: () => styleSelected('fontWeight', 'bold'), className: 'bg-gray-700 px-2 rounded' }, h('b', null, 'B')),
                            h('button', { onClick: () => styleSelected('fontStyle', 'italic'), className: 'bg-gray-700 px-2 rounded' }, h('i', null, 'I')),
                            h('input', { type: 'color', onChange: (e) => styleSelected('fill', e.target.value), className: 'w-8 h-8 rounded' })),
                        h('button', { onClick: exportPNG, className: 'bg-blue-600 px-3 py-1.5 rounded text-sm' }, h('i', { className: 'fas fa-download mr-1' }), 'PNG'),
                        h('button', { onClick: saveDesign, className: 'bg-green-700 px-3 py-1.5 rounded text-sm' }, h('i', { className: 'fas fa-save mr-1' }), 'Save')
                    ),
                    h('div', { className: 'flex justify-center' }, h('canvas', { ref: canvasRef, className: 'border border-gray-600 rounded-xl shadow-xl', style: { maxWidth: '100%', height: 'auto' } })),
                    h('div', { className: 'glass-card p-2 rounded-xl' },
                        h('h4', { className: 'text-sm font-bold' }, 'Layers'),
                        h('div', { className: 'max-h-32 overflow-auto' }, layers.map((l, idx) =>
                            h('div', { key: idx, className: `layer-item p-1 text-xs cursor-pointer ${selectedId === idx ? 'bg-orange-800' : ''}`, onClick: () => { fabricCanvas.current.setActiveObject(fabricCanvas.current.getObjects()[idx]); fabricCanvas.current.renderAll(); setSelectedId(idx); } },
                                h('i', { className: `fas fa-${l.type === 'text' ? 'font' : 'square'} mr-1` }),
                                l.text || l.type
                            )
                        ))
                    )
                );
            };

            // ---------- BRANDING STUDIO ----------
            const BrandingStudio = ({ role }) => {
                const [primary, setPrimary] = useState(loadFromLocal(role, 'brand_primary', '#f97316'));
                const [secondary, setSecondary] = useState(loadFromLocal(role, 'brand_secondary', '#3b82f6'));
                const [font, setFont] = useState(loadFromLocal(role, 'brand_font', 'Inter'));
                const [logo, setLogo] = useState(loadFromLocal(role, 'brand_logo', 'https://placehold.co/200x80/1e293b/f97316?text=APEX+LOGO'));
                const [tempLogo, setTempLogo] = useState('');

                useEffect(() => {
                    saveToLocal(role, 'brand_primary', primary);
                    saveToLocal(role, 'brand_secondary', secondary);
                    saveToLocal(role, 'brand_font', font);
                    saveToLocal(role, 'brand_logo', logo);
                }, [primary, secondary, font, logo, role]);

                const exportZip = async () => {
                    const zip = new JSZip();
                    zip.file("brand.css", `:root{--primary:${primary};--secondary:${secondary};--font:${font}}`);
                    if (logo && logo.startsWith('http')) {
                        try {
                            const res = await fetch(logo);
                            const blob = await res.blob();
                            zip.file("logo.png", blob);
                        } catch(e) {}
                    }
                    const content = await zip.generateAsync({ type: "blob" });
                    saveAs(content, "apex-brand-kit.zip");
                };

                return h('div', { className: 'grid md:grid-cols-2 gap-6' },
                    h('div', { className: 'space-y-4' },
                        h('div', null, h('label', null, 'Primary'), h('input', { type: 'color', value: primary, onChange: e => setPrimary(e.target.value), className: 'w-full h-10 rounded' })),
                        h('div', null, h('label', null, 'Secondary'), h('input', { type: 'color', value: secondary, onChange: e => setSecondary(e.target.value), className: 'w-full h-10 rounded' })),
                        h('div', null, h('label', null, 'Font'), h('select', { value: font, onChange: e => setFont(e.target.value), className: 'bg-gray-800 p-2 rounded w-full' },
                            h('option', { value: 'Inter' }, 'Inter'), h('option', { value: 'Poppins' }, 'Poppins'), h('option', { value: 'Montserrat' }, 'Montserrat'))),
                        h('div', null, h('label', null, 'Logo URL'), h('div', { className: 'flex gap-2' },
                            h('input', { value: tempLogo, onChange: e => setTempLogo(e.target.value), className: 'bg-gray-800 flex-1 p-2 rounded' }),
                            h('button', { onClick: () => tempLogo && setLogo(tempLogo), className: 'bg-orange-600 px-3 rounded' }, 'Set'))),
                        h('button', { onClick: exportZip, className: 'bg-blue-600 w-full py-2 rounded' }, h('i', { className: 'fas fa-file-zipper mr-2' }), 'Download ZIP')
                    ),
                    h('div', { className: 'glass-card p-4 rounded-2xl', style: { backgroundColor: secondary+'20', borderTopColor: primary, borderTopWidth: 4, fontFamily: font } },
                        h('h3', { style: { color: primary }, className: 'text-xl font-bold' }, 'APEX Preview'),
                        h('div', { className: 'flex gap-2 mt-2' },
                            h('span', { className: 'px-3 py-1 rounded text-white', style: { background: primary } }, 'Primary'),
                            h('span', { className: 'px-3 py-1 rounded text-white', style: { background: secondary } }, 'Secondary')
                        ),
                        h('img', { src: logo, className: 'max-h-16 mt-2', alt: 'logo' })
                    )
                );
            };

            // ---------- MARKETING STUDIO ----------
            const MarketingStudio = ({ role, aggressiveBoostFlag, onBoostAcknowledge }) => {
                const [campaigns, setCampaigns] = useState(loadFromLocal(role, 'campaigns', [
                    { id:1, name:"Summer Blast", budget:2500, impressions:45800, clicks:3100, conversions:342 },
                    { id:2, name:"Flash Sale", budget:1200, impressions:23400, clicks:2100, conversions:198 }
                ]));
                const [newCampaign, setNewCampaign] = useState({ name: "", budget: "" });

                useEffect(() => {
                    saveToLocal(role, 'campaigns', campaigns);
                }, [campaigns, role]);

                useEffect(() => {
                    if (aggressiveBoostFlag) {
                        setCampaigns(prev => prev.map(c => ({
                            ...c,
                            impressions: Math.floor(c.impressions * 1.4),
                            clicks: Math.floor(c.clicks * 1.5),
                            conversions: Math.floor(c.conversions * 1.35)
                        })));
                        if (onBoostAcknowledge) onBoostAcknowledge();
                    }
                }, [aggressiveBoostFlag]);

                const addCampaign = () => {
                    if (!newCampaign.name || !newCampaign.budget) return;
                    setCampaigns([...campaigns, {
                        id: Date.now(),
                        name: newCampaign.name,
                        budget: parseInt(newCampaign.budget),
                        impressions: Math.floor(Math.random()*20000)+5000,
                        clicks: Math.floor(Math.random()*2000),
                        conversions: Math.floor(Math.random()*200)
                    }]);
                    setNewCampaign({ name: "", budget: "" });
                };
                const exportCSV = () => {
                    const headers = ["Name","Budget","Impressions","Clicks","Conversions"];
                    const rows = campaigns.map(c => [c.name, c.budget, c.impressions, c.clicks, c.conversions]);
                    const csv = [headers, ...rows].map(row => row.join(",")).join("\n");
                    const blob = new Blob([csv], { type: "text/csv" });
                    saveAs(blob, "campaigns.csv");
                };
                const totals = campaigns.reduce((acc,c) => ({
                    impressions: acc.impressions + c.impressions,
                    clicks: acc.clicks + c.clicks,
                    conversions: acc.conversions + c.conversions,
                    budget: acc.budget + c.budget
                }), {impressions:0, clicks:0, conversions:0, budget:0});

                return h('div', { className: 'space-y-5' },
                    h('div', { className: 'grid grid-cols-2 md:grid-cols-4 gap-3' },
                        h('div', { className: 'glass-card p-2 text-center' }, h('i', { className: 'fas fa-eye' }), h('p', { className: 'text-xl font-bold' }, totals.impressions.toLocaleString()), h('p', { className: 'text-xs' }, 'Impressions')),
                        h('div', { className: 'glass-card p-2 text-center' }, h('i', { className: 'fas fa-mouse-pointer' }), h('p', { className: 'text-xl font-bold' }, totals.clicks.toLocaleString()), h('p', { className: 'text-xs' }, 'Clicks')),
                        h('div', { className: 'glass-card p-2 text-center' }, h('i', { className: 'fas fa-chart-line' }), h('p', { className: 'text-xl font-bold' }, totals.conversions), h('p', { className: 'text-xs' }, 'Conversions')),
                        h('div', { className: 'glass-card p-2 text-center' }, h('i', { className: 'fas fa-chart-simple' }), h('p', { className: 'text-xl font-bold' }, ((totals.conversions*45)/totals.budget || 0).toFixed(1) + '%'), h('p', { className: 'text-xs' }, 'Est. ROI'))
                    ),
                    h('div', { className: 'glass-card p-4 rounded-2xl' },
                        h('div', { className: 'flex justify-between' }, h('h4', { className: 'font-bold' }, 'Campaigns'), h('button', { onClick: exportCSV, className: 'bg-green-700 text-xs px-2 py-1 rounded' }, 'CSV')),
                        h('div', { className: 'max-h-64 overflow-auto space-y-2 mt-2' }, campaigns.map(c =>
                            h('div', { key: c.id, className: 'bg-gray-800 p-2 rounded flex justify-between text-sm' },
                                h('span', null, h('b', null, c.name), ` ($${c.budget})`),
                                h('span', null, `${c.impressions} / ${c.clicks} / ${c.conversions}`)
                            )
                        )),
                        h('div', { className: 'flex gap-2 mt-3' },
                            h('input', { placeholder: 'Name', value: newCampaign.name, onChange: e => setNewCampaign({...newCampaign, name: e.target.value}), className: 'bg-gray-700 p-2 rounded flex-1 text-sm' }),
                            h('input', { placeholder: '$ Budget', type: 'number', value: newCampaign.budget, onChange: e => setNewCampaign({...newCampaign, budget: e.target.value}), className: 'bg-gray-700 p-2 rounded w-28 text-sm' }),
                            h('button', { onClick: addCampaign, className: 'bg-orange-600 px-3 rounded' }, '+')
                        )
                    )
                );
            };

            // ---------- PAYMENT SYSTEM ----------
            const PaymentSystem = ({ role, onPaymentVerified }) => {
                const [requests, setRequests] = useState(loadFromLocal(role, 'payment_requests', []));
                const [amount, setAmount] = useState('');
                const [reason, setReason] = useState('');
                const [isPro, setIsPro] = useState(() => loadFromLocal(role, 'pro_status', false));

                const createRequest = () => {
                    if (!amount || parseFloat(amount) <= 0) return alert("Enter amount");
                    const ref = `${BANK_DETAILS.referencePrefix}-${Math.floor(Math.random()*100000)}`;
                    const newReq = { id: Date.now(), amount: parseFloat(amount), reason: reason || "Pro Upgrade", reference: ref, status: "pending", date: new Date().toISOString(), proofDataU
